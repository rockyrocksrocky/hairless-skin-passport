# Копирай този файл в .env и попълни реалните стойности
# Никога не commit-вай .env файла в git!

PRIVATE_KEY=твоят_тестов_wallet_private_key_без_0x

# По избор - custom RPC (иначе ползва публичните)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# От https://basescan.org/myapikey (безплатна регистрация)
BASESCAN_API_KEY=
